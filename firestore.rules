rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }
    match /user_stats/{statId} {
      allow read: if request.auth != null && request.auth.uid == statId;
      allow update: if request.auth != null && request.auth.uid == statId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.user_id;
    }
  }
}